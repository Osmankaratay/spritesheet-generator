{
  "name": "spritesheet-generator-backend",
  "version": "0.1.0",
  "description": "Backend for 2D Spritesheet Generator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "db:migrate": "node -r ts-node/register migrations/migrate.ts",
    "db:rollback": "node -r ts-node/register migrations/rollback.ts",
    "db:seed": "node -r ts-node/register migrations/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.2",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^4.6.12",
    "axios": "^1.6.2",
    "openai": "^4.28.0",
    "multer": "^1.4.5",
    "sharp": "^0.33.0",
    "aws-sdk": "^2.1540.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
