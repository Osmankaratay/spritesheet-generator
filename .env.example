# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/spritesheet_generator
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spritesheet_generator
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# AI/Generation APIs
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
IMAGE_GENERATION_API_KEY=your_image_generation_api_key
KLING_API_KEY=your_kling_api_key

# Rate Limiting
DEFAULT_RATE_LIMIT_QUOTA=50
RATE_LIMIT_RESET_TIME=00:00:00
RATE_LIMIT_TIMEZONE=UTC

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.txt,.pdf,.doc,.docx
UPLOAD_DIR=./uploads

# Session
SESSION_SECRET=your_session_secret_key_here
SESSION_TIMEOUT=3600000

# AWS S3 (for asset storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=spritesheet-generator-assets

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@spritesheet-generator.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Admin Settings
ADMIN_EMAIL=admin@spritesheet-generator.com
